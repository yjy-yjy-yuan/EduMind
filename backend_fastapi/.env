# AI-EdVision FastAPI Backend Configuration
# 复制此文件为 .env 并根据需要修改

# 应用配置
APP_NAME=AI-EdVision
DEBUG=true
HOST=127.0.0.1
PORT=2004
SECRET_KEY=dev-secret-key-change-in-production

# 数据库配置
DATABASE_URL=sqlite:///./app.db

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# 通义千问 API 配置
OPENAI_API_KEY=sk-59a6a7690bfb42cd887365795e114002
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:8b

# Whisper 配置
# 可选模型: tiny, base, small, medium, large, turbo (按性能从低到高排序)
# 英语专用模型: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=turbo
WHISPER_MODEL_PATH=~/Desktop/File/graduation/whisper

# CORS 配置 (多个域名用逗号分隔)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis 配置 (可选)
REDIS_URL=redis://localhost:6379/0
