# AI-EdVision FastAPI Backend Configuration
# 开发环境配置 (.env)
# 生产环境请使用 .env.production

# ========== 环境配置 ==========
# 可选值: local, development, production
APP_ENV=local

# ========== 应用配置 ==========
APP_NAME=AI-EdVision
DEBUG=true
HOST=0.0.0.0
PORT=2004
SECRET_KEY=dev-secret-key-change-in-production

# ========== 数据库配置 (MySQL) ==========
DATABASE_URL=mysql+pymysql://root:yjy200603@127.0.0.1:3306/edumind

# ========== Neo4j 配置 ==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cjx20040328

# ========== LLM API 配置 (通义千问) ==========
# 通义千问 API 密钥 (https://dashscope.console.aliyun.com/)
OPENAI_API_KEY=sk-59a6a7690bfb42cd887365795e114002
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-df74c99ea0e34ef5a76591c71cd4ccf9
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== Ollama 配置 (本地 AI) ==========
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:8b

# ========== Whisper 配置 (语音识别) ==========
# 可选模型: tiny, base, small, medium, large, turbo (按性能从低到高排序)
# 英语专用模型: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=turbo
WHISPER_MODEL_PATH=~/Desktop/File/graduation/whisper

# ========== CORS 配置 ==========
# 多个域名用逗号分隔
CORS_ORIGINS=null,http://localhost:328,http://127.0.0.1:328

# ========== Redis 配置 (可选) ==========
REDIS_URL=redis://localhost:6379/0
