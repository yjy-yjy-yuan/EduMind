# AI-EdVision FastAPI 环境配置

# 应用配置
APP_NAME=AI-EdVision
DEBUG=true
HOST=127.0.0.1
PORT=2004
SECRET_KEY=your-secret-key-change-in-production

# 数据库配置
DATABASE_URL=sqlite:///./app.db
# 生产环境使用 MySQL:
# DATABASE_URL=mysql+pymysql://root:password@localhost/ai_edvision

# Neo4j 配置
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM API 配置 (通义千问/OpenAI 兼容)
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Ollama 配置
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:8b

# Whisper 配置
# 可选模型: tiny, base, small, medium, large, turbo (按性能从低到高排序)
# 英语专用模型: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=turbo
WHISPER_MODEL_PATH=~/Desktop/File/graduation/whisper

# CORS 配置 (逗号分隔多个源)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Redis 配置 (可选, 用于 Celery)
REDIS_URL=redis://localhost:6379/0
