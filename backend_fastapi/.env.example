# AI-EdVision FastAPI 环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# ========== 环境配置 ==========
# 可选值: local, development, production
APP_ENV=local

# ========== 应用配置 ==========
APP_NAME=AI-EdVision
DEBUG=true
# 真机连调时改为 0.0.0.0；固定域名部署时若直连本机可为 0.0.0.0，若前有 Nginx 反向代理可为 127.0.0.1
HOST=127.0.0.1
PORT=2004
SECRET_KEY=your-secret-key-change-in-production

# ========== 数据库配置 (MySQL) ==========
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/ai_edvision

# ========== Neo4j 配置 ==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ========== LLM API 配置 (通义千问) ==========
# 通义千问 API 密钥 (https://dashscope.console.aliyun.com/)
OPENAI_API_KEY=your-qwen-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== Ollama 配置 (本地 AI) ==========
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:8b

# ========== Whisper 配置 (语音识别) ==========
# 可选模型: tiny, base, small, medium, large, turbo (按性能从低到高排序)
# 英语专用模型: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=turbo
WHISPER_MODEL_PATH=~/Desktop/File/graduation/whisper

# ========== 文件上传目录 ==========
# 不设置时默认为 backend_fastapi/uploads；已上传的视频文件存放在此目录下
# UPLOAD_FOLDER=

# ========== CORS 配置 ==========
# 多个域名用逗号分隔。真机连调时加入 http://<Mac的局域网IP>:5173（Mac 上执行 ipconfig getifaddr en0 可得 IP）
# 固定域名部署时改为前端实际来源，例如：CORS_ORIGINS=https://h5.yourdomain.com,https://yourdomain.com（详见 docs/BACKEND_FIXED_DOMAIN.md）
# CORS_ORIGINS=http://localhost:328,http://127.0.0.1:328,http://localhost:5173,http://127.0.0.1:5173,http://192.168.1.10:5173
CORS_ORIGINS=http://localhost:328,http://127.0.0.1:328,http://localhost:5173,http://127.0.0.1:5173

# ========== Redis 配置 (可选) ==========
REDIS_URL=redis://localhost:6379/0
