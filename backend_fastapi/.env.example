# EduMind FastAPI 环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# ========== 环境配置 ==========
# 可选值: local, development, production
APP_ENV=local

# ========== 应用配置 ==========
APP_NAME=EduMind
DEBUG=true
# 真机/iOS 设备访问时必须监听所有网卡；固定域名部署时若前有 Nginx 反向代理也可维持 127.0.0.1
HOST=0.0.0.0
PORT=2004
SECRET_KEY=your-secret-key-change-in-production
# 登录 token 有效期（秒）与校验时钟偏差（秒），须与 app/utils/auth_token.py 一致
AUTH_TOKEN_TTL_SECONDS=604800
AUTH_TOKEN_CLOCK_SKEW_SECONDS=120
# 默认关闭自动建表，避免启动时擅自变更现有 MySQL 表结构；如需初始化请手动运行 scripts/init_db.py
AUTO_CREATE_TABLES=false

# ========== 数据库配置 (MySQL) ==========
DATABASE_URL=mysql+pymysql://root:your_password@127.0.0.1:3306/edumind

# ========== LLM API 配置 (通义千问 / DeepSeek) ==========
# 通义千问 API 密钥 (https://dashscope.console.aliyun.com/)
OPENAI_API_KEY=your-qwen-api-key-here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
QA_DEFAULT_PROVIDER=qwen
QWEN_QA_MODEL=qwen-plus
DEEPSEEK_QA_MODEL=deepseek-chat
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
QA_TOP_K=4
QA_MAX_CONTEXT_CHARS=4500
QA_MAX_HISTORY_MESSAGES=8
QA_MAX_HISTORY_CHARS=2200

# ========== Sleek 设计能力（可选） ==========
# 该能力源自 sleek.design 的 agent-skills 方案，但接入方式是通过 EduMind 后端统一代理，前端与 iOS 容器不直接暴露第三方密钥。
# 先在 https://sleek.design/dashboard/api-keys 创建 API Key，并至少授予 projects:read / projects:write / components:read / chats:read / chats:write / screenshots 所需 scope。
SLEEK_API_KEY=
SLEEK_API_BASE=https://sleek.design
SLEEK_PROJECT_LIMIT=50
SLEEK_POLL_TIMEOUT_SECONDS=300
SLEEK_POLL_INITIAL_INTERVAL_SECONDS=2
SLEEK_POLL_BACKOFF_AFTER_SECONDS=10
SLEEK_POLL_BACKOFF_INTERVAL_SECONDS=5

# ========== Ollama 配置 (仅保留给非问答场景兼容能力) ==========
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen-3.5:9b

# ========== Whisper 配置 (语音识别) ==========
# 可选模型: tiny, base, small, medium, large, turbo (按性能从低到高排序)
# 英语专用模型: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL=base
WHISPER_MODEL_PATH=/Users/yuan/302_works/whisper_models
# 服务启动后是否后台预热默认 Whisper 模型，减少首个转录任务的等待时间
WHISPER_PRELOAD_ON_STARTUP=true
# 模型已存在于本地时使用较短超时，避免加载异常时长时间卡住
WHISPER_LOAD_TIMEOUT_SECONDS=60
# 模型首次下载时允许更长超时，兼容 medium/large 等大模型
WHISPER_DOWNLOAD_TIMEOUT_SECONDS=300

# ========== 文件上传目录 ==========
# 不设置时默认为 backend_fastapi/uploads；已上传的视频文件存放在此目录下
# UPLOAD_FOLDER=

# ========== CORS 配置 ==========
# 多个来源用逗号分隔；iOS WKWebView 从本地 file:// 加载时，远程请求的 Origin 通常是 `null`，务必保留。
# 固定域名部署时改为前端实际来源，例如：CORS_ORIGINS=null,https://h5.yourdomain.com,https://yourdomain.com（详见 docs/BACKEND_FIXED_DOMAIN.md）
CORS_ORIGINS=null,http://localhost:328,http://127.0.0.1:328,http://localhost:5173,http://127.0.0.1:5173

# ========== 视频推荐（站内候选上限、站外默认与超时） ==========
# RECOMMENDATION_MAX_CANDIDATES_SCAN=400
# RECOMMENDATION_INCLUDE_EXTERNAL_DEFAULT=false
# RECOMMENDATION_EXTERNAL_TIMEOUT_SECONDS=8
# RECOMMENDATION_EXTERNAL_FETCH_PARALLEL=true
# RECOMMENDATION_EXTERNAL_FETCH_RETRIES=1

# ========== 语义搜索（默认推荐本地字幕语义搜索） ==========
SEARCH_ENABLED=false
SEARCH_BACKEND=local
SEARCH_LOCAL_MODEL=hashing-char-ngrams-zh
SEARCH_GEMINI_API_KEY=
SEARCH_CHROMA_DB_DIR=./data/chroma
SEARCH_ADAPTIVE_CHUNKING=true
SEARCH_CHUNK_DURATION=30
SEARCH_CHUNK_OVERLAP=5
SEARCH_SIMILARITY_THRESHOLD=0.5
SEARCH_PREPROCESS=true
SEARCH_PREPROCESS_RESOLUTION=480
SEARCH_PREPROCESS_FPS=5
SEARCH_AUTO_INDEX_NEW_VIDEOS=true

# ========== Redis 配置 (可选) ==========
REDIS_URL=redis://localhost:6379/0
