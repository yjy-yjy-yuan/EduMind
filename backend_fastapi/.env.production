# AI-EdVision FastAPI Backend Configuration
# 生产环境配置 (.env.production)
# 使用方法: cp .env.production .env 然后修改敏感配置

# ========== 环境配置 ==========
APP_ENV=production

# ========== 应用配置 ==========
APP_NAME=AI-EdVision
DEBUG=false
HOST=0.0.0.0
PORT=2004
# 生产环境必须修改为随机强密钥
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY

# ========== 数据库配置 ==========
# 生产环境建议使用 PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_edvision
DATABASE_URL=sqlite:///./app.db

# ========== Neo4j 配置 ==========
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# 生产环境必须修改密码
NEO4J_PASSWORD=CHANGE_THIS_PASSWORD

# ========== LLM API 配置 (通义千问) ==========
# 通义千问 API 密钥 (https://dashscope.console.aliyun.com/)
# 生产环境必须配置有效的 API 密钥
OPENAI_API_KEY=YOUR_QWEN_API_KEY_HERE
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ========== Ollama 配置 (本地 AI) ==========
OLLAMA_BASE_URL=http://localhost:11434/api
OLLAMA_MODEL=qwen3:8b

# ========== Whisper 配置 (语音识别) ==========
# 生产环境建议使用 large 或 turbo 模型以获得更好的识别效果
WHISPER_MODEL=turbo
WHISPER_MODEL_PATH=/opt/whisper/models

# ========== CORS 配置 ==========
# 生产环境应该限制为实际的前端域名
CORS_ORIGINS=https://your-production-domain.com

# ========== Redis 配置 (可选) ==========
REDIS_URL=redis://localhost:6379/0
