# =============================================================================
# EduMind Mobile Frontend - 生产 / 固定域名构建环境变量示例
# =============================================================================
# 复制此文件为 .env.production 并修改为实际值:
#   cp .env.production.example .env.production
#   编辑 .env.production，将 https://api.xxx.com 替换为你的实际后端固定域名
#
# 重要: .env.production 用于生产 Web 部署（npm run build 或 npm run build:web）。
#       iOS 打包请使用 .env.ios（见 .env.ios.example）。
#
# 详见 docs/BACKEND_FIXED_DOMAIN.md
# =============================================================================

# 后端固定域名（必须替换为真实 HTTPS 地址）
VITE_MOBILE_API_BASE_URL=https://api.xxx.com

# 纯 UI 模式（生产环境关闭，需要真实后端）
VITE_MOBILE_UI_ONLY=false

# 本地代理目标（生产构建时不使用，仅开发参考）
VITE_MOBILE_PROXY_TARGET=http://127.0.0.1:2004

# 推荐能力（按需开启）
# VITE_RECOMMENDATION_INCLUDE_EXTERNAL=false
