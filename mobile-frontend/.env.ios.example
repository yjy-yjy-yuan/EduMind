# =============================================================================
# EduMind Mobile Frontend - iOS / Release / TestFlight 构建环境变量示例
# =============================================================================
# 复制此文件为 .env.ios 并修改为实际值:
#   cp .env.ios.example .env.ios
#   编辑 .env.ios，将 https://api.xxx.com 替换为你的实际后端固定域名
#
# 重要: .env.ios 用于 iOS 打包（npm run build:ios），构建产物会嵌入此地址。
#       不要在 .env.ios 中使用 .local / 127.0.0.1 / 私网 IP，否则 TestFlight 会失败。
#
# 本地 Debug 开发仍使用 .env（默认指向 127.0.0.1:2004），不会影响 .env.ios。
# =============================================================================

# 后端固定域名（必须替换为真实 HTTPS 地址）
VITE_MOBILE_API_BASE_URL=https://api.xxx.com

# 纯 UI 模式（固定域名场景通常关闭，因为需要真实后端）
VITE_MOBILE_UI_ONLY=false

# 本地代理目标（仅本地开发使用，固定域名构建时会被 VITE_MOBILE_API_BASE_URL 覆盖）
VITE_MOBILE_PROXY_TARGET=http://127.0.0.1:2004

# 推荐能力（固定域名部署时可按需开启）
# VITE_RECOMMENDATION_INCLUDE_EXTERNAL=false
