# 移动应用后端 API 基地址（真机=前端、通过端口连调）
# 本机浏览器调试：http://127.0.0.1:2004
# 真机连调：改为 http://<Mac的局域网IP>:2004；Mac 上获取 IP：终端执行 ipconfig getifaddr en0
VITE_MOBILE_API_BASE_URL=http://127.0.0.1:2004

# 是否仅 UI 模式（true=走 mock，false=请求真实后端，用于视频上传/播放/登录等）
VITE_MOBILE_UI_ONLY=false

# 历史：部分构建脚本仍可读；未设置首页专用项时，可被其它逻辑引用
VITE_RECOMMENDATION_INCLUDE_EXTERNAL=false

# 首页「为你推荐」是否请求站外并走后端自动入库闭环（默认 true，与推荐中枢一致）
# 弱网或仅想首屏更快时可设为 false
VITE_RECOMMENDATION_HOME_INCLUDE_EXTERNAL=true

# 可选：Vite dev server 代理目标
VITE_MOBILE_PROXY_TARGET=http://127.0.0.1:2004
