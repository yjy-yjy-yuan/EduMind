graph TB
    subgraph Frontend["前端交互层"]
        UI["用户界面"]
        VA["视频播放器"]
        NE["笔记编辑器"]
        VM["可视化模块"]
    end

    subgraph Core["核心服务层"]
        VIS["智能视频理解系统"]
        NOS["AI智能笔记系统"]
        AIS["智能学习助手"]
        LMS["学习进度管理"]
        LPS["个性化学习路径"]
        DAS["数据分析系统"]
    end

    subgraph AI["AI引擎层"]
        WHI["Whisper语音识别"]
        LLM["大语言模型"]
        SPA["SpaCy NLP"]
        KGE["知识图谱引擎"]
    end

    subgraph Data["数据存储层"]
        VDB["视频数据库"]
        NDB["笔记数据库"]
        KDB["知识库"]
        UDB["用户数据库"]
    end

    UI --> VIS
    UI --> NOS
    UI --> AIS
    UI --> LMS
    UI --> LPS
    UI --> DAS

    VIS --> WHI
    NOS --> LLM
    NOS --> SPA
    AIS --> LLM
    LPS --> KGE

    WHI --> VDB
    GPT --> KDB
    SPA --> NDB
    KGE --> KDB

    VA --> UI
    NE --> UI
    VM --> UI
