[flake8]
max-line-length = 120
max-complexity = 18
select = B,C,E,F,W,T4,B9
ignore = E203,E266,E501,E503,W503,F403,E231,B950,C901,B008,B007,F401,F402,F811,F821,F841,F541,E722,E402
exclude =
    .git,
    __pycache__,
    migrations,
    uploads,
    logs,
    docs,
    dist,
    build,
    .venv,
    venv,
    *.pyc,
    test_src
per-file-ignores =
    __init__.py:F401
